# @defaultSensitive=inferFromPrefix('NEXT_PUBLIC_')
# @generateTypes(lang=ts, path=env.d.ts)
# ----------



# ── Brewfather API credentials ───────────────────────────────────────────────

# Brewfather User ID — found in Brewfather → Settings → API.
# @required
BREWFATHER_USER_ID=exec(`doppler secrets get BREWFATHER_USER_ID --plain -p brewfather-mcp -c dev`)

# Brewfather API Key — found in Brewfather → Settings → API.
# @required
BREWFATHER_API_KEY=exec(`doppler secrets get BREWFATHER_API_KEY --plain -p brewfather-mcp -c dev`)

# ── MCP / OAuth ──────────────────────────────────────────────────────────────

# Static secret used to sign OAuth tokens for the remote MCP connector.
# Not used in stdio mode (Claude Desktop passes credentials directly).
# @required
MCP_AUTH_TOKEN=exec(`doppler secrets get MCP_AUTH_TOKEN --plain -p brewfather-mcp -c dev`)
