{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src/mcp",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": false,
    "resolveJsonModule": true
  },
  "include": ["src/mcp/**/*.ts"],
  "exclude": ["node_modules", "app", ".next"]
}
